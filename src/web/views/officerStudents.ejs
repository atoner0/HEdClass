<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Management</title>

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"
    />

    <link rel="stylesheet" href="/myui.css" />
  </head>

  <body>
    <main class="container-fluid">
      <nav class="user-nav">
        <div class="left">
          <ul class="user-title">
            <li><h3>Student Management</h3></li>
          </ul>
          <ul class="user-btns">
            <li><a href="/officer" class="nav-btn">Home</a></li>
          </ul>
        </div>
        <div class="right">
          <ul class="logout">
            <li>Hello <%= user.username %> </li>
            <li><a href="/logout" class="nav-btn">Log Out</a></li>
          </ul>
        </div>
      </nav>
       <div class="user-content">
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th scope="col">ID</th>
                <th scope="col">Student No.</th>
                <th scope="col">First Name</th>
                <th scope="col">Surname</th>
                <th scope="col">Email</th>
                <th scope="col">Study Year</th>
                <th scope="col">Graduation Year</th>
                <th scope="col"></th>
                <th scope="col"></th>
                <th scope="col"></th>
              </tr>
            </thead>
            <tbody>
              <% students.forEach(student => { %>
              <tr>
                <th scope="row"><%= student.id %></th>
                <td><%= student.student_no %></td>
                <td><%= student.first_name %></td>
                <td><%= student.last_name %></td>
                <td><%= student.email %></td>
                <td><%= student.study_year %></td>
                <td><%= student.graduation_year %></td>
                <td><a href="/officer/programme/<%= programmeId %>/student/<%= student.id %>/results" class="table-btn">Results</a></td>
                <td><a href="/officer/programme/<%= programmeId %>/student/<%= student.id %>/edit" class="table-btn">Edit</a></td>
                <td><form action="/officer/programme/<%= programmeId %>/student/delete/<%= student.id %>" method="POST">
                          <button class="table-btn">Delete</button>
                </form></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        
        <div class = "cohort-btns">
            <a href = "/officer/programme/<%= programmeId %>/student/add" class = "manage"> Add Student </a>
            
          <button type = "button" class = "manage" onclick="runBatchClassification(<%= programmeId %>)">
            Run Batch Classification
          </button>
          <dialog id="resultModal">
            <article>
              <header>
                <h4> Batch Classification </h4>
              </header>
                <p id="modalMessage"></p>
                <form method="dialog">
                    <button class="modal-btn">OK</button>
                </form>
              </article>
            </dialog>

          <script>
            function showModal(message){
              const dialog = document.getElementById("resultModal");
              const text = document.getElementById("modalMessage");

              text.textContent = message;
              dialog.showModal();
            }

            async function runBatchClassification(programmeId){
              try {
                const response = await fetch(`/api/programmes/${programmeId}/classifications/run`, {method: "POST"});

                const data = await response.json();

                if(!response.ok){
                  showModal(data.error || "Batch classification failed");
                  return;
                }

                showModal(data.message);

              } catch (error){
                showModal("Something went wrong while running batch classification");
              }
            }
          </script>
            <button id = "btnExportToCSV" class="manage">Export Classifications to CSV</button>
          <script src = "/js/CSVDownload.js"></script>
          <script>

            const btnExportToCSV = document.getElementById("btnExportToCSV");

            const programme = "<%= programme.title %>";
            const classifications = <%- JSON.stringify(classifications) %>;

            btnExportToCSV.addEventListener("click", () => {

              const lines = [
                `Programme,${programme}`,
                "",
                ["Student No", "Name", "Final Classification", "Final Average"].join(",")
              ];
              
              classifications.forEach(student => {
                const studentName = `${student.first_name} ${student.last_name}`;
                let finalClass = student.override_class || student.proposed_class;

                const row = [
                    student.student_no,
                    studentName,
                    finalClass,
                    Number(student.final_avg).toFixed(2)
                ].map(value => {
                  value = String(value ?? "").replace(/"/g, '""');
                  return `"${value}"`
                });

                lines.push(row.join(","));
              })

              downloadCSV(lines, `${programme}-classifications.csv`)
            
            })
          </script>
      </div>
    </main>
  </body>
</html>
