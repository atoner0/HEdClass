<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Management</title>

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"
    />

    <link rel="stylesheet" href="/myui.css" />
  </head>

  <body>
    <main class="container-fluid">
      <nav class="user-nav">
        <div class="left">
          <ul class="user-title">
            <li><h3>Student Management</h3></li>
          </ul>
          <ul class="user-btns">
            <li><a href="/officer" class="nav-btn">Home</a></li>
            <li><a href="/officer/programme/<%= programme.id %>/students" class="nav-btn">Students</a></li>
          </ul>
        </div>
        <div class="right">
          <ul class="logout">
            <li>Hello <%= user.username %> </li>
            <li><a href="/logout" class="nav-btn">Log Out</a></li>
          </ul>
        </div>
      </nav>
       <div class="user-content">
        <hr class="rounded">
        <div class="student-content">
            <div class="student-info">
                <h4><%= student.student_no %> | <%= student.first_name %> <%= student.last_name %> </h4>
                <p><strong>Programme: </strong> <%= programme.title %></p>
                <p><strong>Graduation Year: </strong> <%= student.graduation_year %></p>
                <p><strong>Email: </strong> <%= student.email %> </p>
            </div> 
            <div class ="edit-btn">
                <a href="/officer/programme/<%= programme.id %>/student/<%= student.id %>/edit" class="manage">Edit Student Info</a>
            </div>
        </div>
        <hr class="rounded">

          <div class="student-table">

              <% Object.keys(groupedModules).forEach(year => { %>
                  <div class="year"><h5> Year: <%= year %></h5></div>
              <div class="table-wrapper">
              <table class = "studentResultsTable">
                <thead>
                  <tr>
                    <th scope="col">Module Code</th>
                    <th scope="col">Title</th>
                    <th scope="col">Credits</th>
                    <th scope="col">Attempt</th>
                    <th scope="col">Mark</th>
                    <th scope="col">Capped Mark</th>
                    <th scope="col">Grade</th>
                    <th scope="col" class="no-export"></th>
                    <th scope="col" class="no-export"></th>
                  </tr>
                </thead>
                <tbody>
                  <% groupedModules[year].forEach(mod => { %>
                  <tr>
                    <th scope="row"><%= mod.module_code %></th>
                    <td><%= mod.module_title %></td>
                    <td class ="center"><%= mod.credits %></td>
                    <td class ="<%= mod.attempt_no > 1 ? 'resit' : 'center' %>"> <%= mod.attempt_no > 1 ? `Resit (Attempt ` + mod.attempt_no + `)` :`1` %></td>
                    <td class = "center"><%= mod.mark %> </td>
                    <td class = "center"><%= mod.capped_mark %></td>
                    <td> <%= mod.passed ? 'Pass' : 'Fail' %></td>
                    <td class="no-export"><a href="/officer/programme/<%= programme.id %>/student/<%= student.id %>/result/<%= mod.resultId %>/edit" class="table-btn">Edit</a></td>
                    <td class="no-export"><form action="/officer/programme/<%= programme.id %>/student/<%= student.id %>/result/<%= mod.resultId %>/delete" method="POST">
                              <button class="table-btn">Delete</button>
                    </form></td>
                  </tr>
                  <% }) %>
                  <tr class = "result-stats">
                      <td colspan="4"></td>
                      <td colspan="2">
                          <strong>Credits passed:</strong> <%= creditsByYear[year] %>/120 </td>
                        <td colspan="2" class="right-align">
                          <strong>Average Grade:</strong> <%= avgByYear[year] %>
                      </td>
                  </tr>
                </tbody>
              </table>  
            </div>
        </div>
        
        <div class = "manage-btn">
          <a href = "/officer/programme/<%= programme.id %>/student/<%= student.id %>/result/add" class = "manage"> Add Result </a>
        </div>     
        <% }) %>
        <div class = "export-btn">
                  <button id = "btnExportToCSV" class="manage">Export to CSV</button>
        <script src = "/js/tableCSVExporter.js"></script>
        <script>
          const tables = document.querySelectorAll(".studentResultsTable");

          const btnExportToCSV = document.getElementById("btnExportToCSV");

          btnExportToCSV.addEventListener("click", () => {
            //holding all tables, including headers
            const exporters = Array.from(tables).map(table => new TableCSVExporter(table));
          
            const csvOutput = exporters.map(exporter => exporter.convertToCSV()).join("\n\n");

            //blob is container for random data
            //here creating blob of CSV
            const csvBlob = new Blob([csvOutput], {type: "text/csv"});
            const blobUrl = URL.createObjectURL(csvBlob);

            const anchorElement = document.createElement("a");

           anchorElement.href = blobUrl;
           anchorElement.download = "student-results-table.csv";
           anchorElement.click();

           //tells browser to forget about reference to blob
           //reducing memory usage!
           setTimeout(() => {
            URL.revokeObjectURL(blobUrl);
           }, 500);
          })
          
          
        </script>
        </div>

      </div>
      <div class="student-classification">
        <hr class="rounded">
        <div class="classification">
          <div class="student-info">
            <h3>Classification:</h3>
            <% if (!approved && !override) { %>
              <p><strong>Proposed Classification: </strong> <%= proposedClass %></p>
              <hr class="dashed">
              <p><strong>Decision Rationale: </strong></p>
              <div>
                <%- rationale %>
              </div>
              <% if (needsReview) { %>
                <p class = "flag"><strong>Manual Review Required</strong></p>
                <p><strong>Review reason: </strong> <%= reviewReason %></p>
              <% } %>
            <hr class="dashed">
          <% } else if (override) { %>
            <p><strong>Final Classification: </strong> <%= finalClass %></p>
            <p><strong>Override Reason: </strong> <%= finalReason %> </p>
            <hr class="dashed">
              <p><strong>Decision Rationale: </strong></p>
              <div>
                <%- rationale %>
              </div>
            <hr class="dashed">
          <% } else if (approved) {%>
            <p><strong>Final Classification: </strong> <%= finalClass %></p>
            <p><strong>Reason: </strong> <%= reason %> </p>
            <hr class="dashed">
              <p><strong>Decision Rationale: </strong></p>
              <div>
                <%- rationale %>
              </div>
            <hr class="dashed">
            <% } %>
          </div>
          <div class="classification-btns">
            <div class ="edit-btn">
              <td><form action="/officer/programme/<%= programme.id %>/student/<%= student.id %>/approve" method="POST">
                        <button class="manage">Approve Classification</button>
              </form></td>
            </div>
            <div class ="edit-btn">
                <a href="/officer/programme/<%= programme.id %>/student/<%= student.id %>/override" class="manage">Override Classification</a>
            </div>
          </div>
        </div>
        <hr class="rounded">
      </div>
      </div>
    </main>
  </body>
</html>
